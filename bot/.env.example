# Скопируй в .env (он в .gitignore) и заполни. В проде эти же значения — в env Vercel.

# Telegram бот-магазин (@BotFather)
BOT_TOKEN=
BOT_USERNAME=skipa_pay_bot

# Crypto Pay (@CryptoBot → Crypto Pay → Create App)
CRYPTOPAY_TOKEN=

# Кому слать уведомления об оплатах (твой Telegram user id)
OWNER_CHAT_ID=

# Цена и выдача
PRICE_USD=5
REPO_URL=https://github.com/skipaoff/call-summary

# Секрет для проверки вебхука Telegram (любая случайная строка)
TELEGRAM_WEBHOOK_SECRET=
